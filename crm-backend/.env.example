# CRM Backend — Environment Variables
# Copy this file to .env and fill in your values

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=xeno_crm
DB_USER=postgres
DB_PASSWORD=your_postgres_password

# Server
PORT=4000

# OpenAI — add your key here before using AI features
OPENAI_API_KEY=your_openai_api_key_here

# Channel Service URL (running locally)
CHANNEL_SERVICE_URL=http://localhost:5000

# This backend's own URL (used by channel service to callback)
CRM_BACKEND_URL=http://localhost:4000
